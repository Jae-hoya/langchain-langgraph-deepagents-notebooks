graph TD
    START(["START"])
    classify["classify<br/><i>classification</i>"]
    technical["handle_technical<br/><i>technical expert</i>"]
    business["handle_business<br/><i>business advisor</i>"]
    casual["handle_casual<br/><i>casual response</i>"]
    END_(["END"])

    START --> classify
    classify -- "technical" --> technical
    classify -- "business" --> business
    classify -- "casual" --> casual
    technical --> END_
    business --> END_
    casual --> END_

    style START fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c,font-weight:bold
    style classify fill:#ffd166,stroke:#d4a843,color:#333,font-weight:bold
    style technical fill:#ed7969,stroke:#c45a4d,color:#fff
    style business fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style casual fill:#d4eff1,stroke:#83ced2,color:#333
    style END_ fill:#ed7969,stroke:#c45a4d,color:#fff,font-weight:bold
