graph TD
    START(["START"])
    A["Node A"]
    cond{"conditional"}
    B["Node B"]
    C["Node C"]
    END_(["END"])

    START --> A
    A --> cond
    cond --> B
    cond --> C
    B --> END_
    C --> END_

    style START fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c,font-weight:bold
    style A fill:#ed7969,stroke:#c45a4d,color:#fff
    style cond fill:#ffd166,stroke:#d4a843,color:#333
    style B fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style C fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style END_ fill:#ed7969,stroke:#c45a4d,color:#fff,font-weight:bold
