graph TD
    Input["user input"]
    Reasoning["model inference<br/><i>Reasoning</i>"]
    Acting["tool call<br/><i>Acting</i>"]
    Observation["Observation of results<br/><i>Observation</i>"]
    Decision{"tool call<br/>Do you need more?"}
    Response["final response"]

    Input --> Reasoning
    Reasoning --> Acting
    Acting --> Observation
    Observation --> Decision
    Decision -- "yes" --> Reasoning
    Decision -- "no" --> Response

    style Input fill:#f0f0f0,stroke:#ccc,color:#333
    style Reasoning fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style Acting fill:#ed7969,stroke:#c45a4d,color:#fff
    style Observation fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style Decision fill:#ffd166,stroke:#d4a843,color:#333
    style Response fill:#f0f0f0,stroke:#ccc,color:#333
