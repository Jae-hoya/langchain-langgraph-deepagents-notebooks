graph LR
    subgraph before["before_model"]
        direction LR
        T1["순방향"] --> bA["A"] --> bB["B"] --> bC["C"]
    end

    subgraph after["after_model"]
        direction LR
        T2["역방향"] --> aC["C"] --> aB["B"] --> aA["A"]
    end

    subgraph wrap["wrap_model"]
        direction LR
        T3["중첩"] --> wA["A"] --> wB["B"] --> wC["C"] --> mc(("model")) --> wC2["C"] --> wB2["B"] --> wA2["A"]
    end

    style bA fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
    style bB fill:#ed7969,stroke:#c45a4d,color:#fff
    style bC fill:#83ced2,stroke:#5ba8ad,color:#1a3a3c
