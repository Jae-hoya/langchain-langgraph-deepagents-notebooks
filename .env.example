# Deep Agents & LangChain 교육 자료에 필요한 API 키
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요.
# cp .env.example .env

# OpenAI API 키 (필수) — https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=your-openai-api-key-here

# Tavily 검색 API 키 (에이전트 도구에서 사용)
TAVILY_API_KEY=your-tavily-api-key-here

# LangSmith (관측성/트레이싱, 선택) — https://smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agent-notebooks

# Langfuse (관측성/트레이싱, 선택) — https://langfuse.com
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Slack (데이터 분석 에이전트, 선택) — https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
